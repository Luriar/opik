# Terraform — never commit state, plans, real var files, or provider cache.
# These can contain account IDs, resource ARNs, endpoints, and secret material.
# (Also covered by the repo-root .gitignore; kept here so the folder is safe
#  even when used standalone or copied to another machine.)

# Local state and backups (may contain rendered values and ARNs)
*.tfstate
*.tfstate.*

# Saved plans (binary; can contain sensitive values)
tfplan
*.tfplan

# Crash logs
crash.log
crash.*.log

# Real variable files — only the *.example templates are committed
*.tfvars
*.tfvars.json
!*.tfvars.example

# Provider plugins / module cache
.terraform/
.terraform.tfstate.lock.info

# CLI config that may carry credentials
.terraformrc
terraform.rc

# Any stray local env files
*.env
.env
