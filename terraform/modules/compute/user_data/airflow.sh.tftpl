#!/bin/bash
set -euo pipefail

exec > >(tee -a /var/log/opik-airflow-bootstrap.log) 2>&1

dnf update -y
dnf install -y docker git awscli jq openssl
systemctl enable --now docker

if ! docker compose version >/dev/null 2>&1; then
  dnf install -y docker-compose-plugin || true
fi

if ! docker compose version >/dev/null 2>&1; then
  compose_arch="$(uname -m)"
  case "$compose_arch" in
    aarch64|arm64) compose_arch="aarch64" ;;
    x86_64|amd64) compose_arch="x86_64" ;;
    *) echo "Unsupported architecture for Docker Compose: $compose_arch" >&2; exit 1 ;;
  esac
  mkdir -p /usr/local/lib/docker/cli-plugins
  curl -fsSL "https://github.com/docker/compose/releases/download/v2.29.7/docker-compose-linux-$compose_arch" \
    -o /usr/local/lib/docker/cli-plugins/docker-compose
  chmod +x /usr/local/lib/docker/cli-plugins/docker-compose
fi

mkdir -p /opt/opik /var/log/opik

%{ if repo_url != "" ~}
if [ -d /opt/opik/repo/.git ]; then
  git -C /opt/opik/repo pull --ff-only || true
else
  git clone "${repo_url}" /opt/opik/repo
fi
%{ else ~}
echo "repo_url is empty. Airflow application deployment is skipped." >&2
exit 1
%{ endif ~}

read_secret_json() {
  aws secretsmanager get-secret-value \
    --region "${aws_region}" \
    --secret-id "$1" \
    --query SecretString \
    --output text
}

json_value() {
  printf '%s' "$1" | jq -r --arg key "$2" '.[$key] // empty'
}

urlencode() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.quote_plus(sys.stdin.read().rstrip("\n")))'
}

generate_fernet_key() {
  python3 -c 'import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
}

generate_secret() {
  python3 -c 'import secrets; print(secrets.token_urlsafe(36))'
}

airflow_db_secret_json="$(read_secret_json "${airflow_db_secret_arn}")"
service_db_secret_json="$(read_secret_json "${service_db_secret_arn}")"
runtime_secret_json="$(read_secret_json "${airflow_secret_arn}" 2>/dev/null || printf '{}')"
if [ "$runtime_secret_json" = "None" ] || [ -z "$runtime_secret_json" ]; then
  runtime_secret_json="{}"
fi

airflow_db_username="$(json_value "$airflow_db_secret_json" username)"
airflow_db_password="$(json_value "$airflow_db_secret_json" password)"
service_db_username="$(json_value "$service_db_secret_json" username)"
service_db_password="$(json_value "$service_db_secret_json" password)"

airflow_db_password_enc="$(printf '%s' "$airflow_db_password" | urlencode)"
service_db_password_enc="$(printf '%s' "$service_db_password" | urlencode)"

airflow_fernet_key="$(json_value "$runtime_secret_json" AIRFLOW__CORE__FERNET_KEY)"
if [ -z "$airflow_fernet_key" ]; then
  airflow_fernet_key="$(generate_fernet_key)"
fi

airflow_webserver_secret_key="$(json_value "$runtime_secret_json" AIRFLOW__WEBSERVER__SECRET_KEY)"
if [ -z "$airflow_webserver_secret_key" ]; then
  airflow_webserver_secret_key="$(generate_secret)"
fi

airflow_admin_username="$(json_value "$runtime_secret_json" _AIRFLOW_WWW_USER_USERNAME)"
if [ -z "$airflow_admin_username" ]; then
  airflow_admin_username="airflow"
fi

airflow_admin_password="$(json_value "$runtime_secret_json" _AIRFLOW_WWW_USER_PASSWORD)"
if [ -z "$airflow_admin_password" ]; then
  airflow_admin_password="$(generate_secret)"
fi

dart_api_keys="$(json_value "$runtime_secret_json" DART_API_KEYS)"
bedrock_api_key="$(json_value "$runtime_secret_json" BEDROCK_API_KEY)"
bedrock_model_id="$(json_value "$runtime_secret_json" BEDROCK_LLM_MODEL_ID)"
if [ -z "$bedrock_model_id" ]; then
  bedrock_model_id="anthropic.claude-3-haiku-20240307-v1:0"
fi

report_schedule="$(json_value "$runtime_secret_json" OPIK_REPORT_PIPELINE_SCHEDULE)"
if [ -z "$report_schedule" ]; then
  report_schedule="0 0 * * *"
fi

cat >/opt/opik/bootstrap.env <<ENV
AWS_REGION=${aws_region}
AWS_DEFAULT_REGION=${aws_region}
S3_BUCKET=${data_bucket_name}
AIRFLOW_DB_ENDPOINT=${airflow_db_endpoint}
SERVICE_DB_ENDPOINT=${service_db_endpoint}
REDIS_PRIMARY_ENDPOINT=127.0.0.1
AIRFLOW_RUNTIME_SECRET_ARN=${airflow_secret_arn}
ENV

umask 077
cat >/opt/opik/airflow.env <<ENV
AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=opik-airflow:2.10.0
AIRFLOW_WORKER_CONCURRENCY=2
_AIRFLOW_WWW_USER_USERNAME=$airflow_admin_username
_AIRFLOW_WWW_USER_PASSWORD=$airflow_admin_password
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://$airflow_db_username:$airflow_db_password_enc@${airflow_db_endpoint}:${airflow_db_port}/${airflow_db_name}
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://$airflow_db_username:$airflow_db_password_enc@${airflow_db_endpoint}:${airflow_db_port}/${airflow_db_name}
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CORE__FERNET_KEY=$airflow_fernet_key
AIRFLOW__WEBSERVER__SECRET_KEY=$airflow_webserver_secret_key
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__DEFAULT_TIMEZONE=Asia/Seoul
AIRFLOW__WEBSERVER__DEFAULT_UI_TIMEZONE=Asia/Seoul
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session
AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK=true
AIRFLOW__WEBSERVER__ENABLE_PROXY_FIX=true
PYTHONPATH=/opt/airflow:/opt/airflow/src:/opt/airflow/pipeline:/opt/airflow/embedding
AWS_EC2_METADATA_DISABLED=false
AWS_REGION=${aws_region}
AWS_DEFAULT_REGION=${aws_region}
S3_REGION=${aws_region}
S3_BUCKET=${data_bucket_name}
S3_BASE_PREFIX=${storage_config.s3_base_prefix}
STORAGE_BACKEND=${storage_config.storage_backend}
LOCAL_STORAGE_BASE_PATH=${storage_config.local_storage_base_path}
BRONZE_PREFIX=${storage_config.bronze_prefix}
SILVER_PREFIX=${storage_config.silver_prefix}
GOLD_PREFIX=${storage_config.gold_prefix}
BEDROCK_REGION=${aws_region}
BEDROCK_API_KEY=$bedrock_api_key
BEDROCK_LLM_MODEL_ID=$bedrock_model_id
SERVICE_DB_URL=postgresql+psycopg2://$service_db_username:$service_db_password_enc@${service_db_endpoint}:${service_db_port}/${service_db_name}
DART_API_KEYS=$dart_api_keys
DART_BACKFILL_MONTHS=${dart_config.backfill_months}
DART_BACKFILL_START_DATE=${dart_config.backfill_start_date}
DART_BACKFILL_END_DATE=${dart_config.backfill_end_date}
DART_INCREMENTAL_DAYS=${dart_config.incremental_days}
DART_LISTED_COMPANY_SCHEDULE=${dart_config.listed_company_schedule}
DART_COLLECT_MODE=${dart_config.collect_mode}
DART_DAILY_LIMIT=${dart_config.daily_limit}
DART_DAILY_SAFE_LIMIT=${dart_config.daily_safe_limit}
DART_DAILY_EMERGENCY_LIMIT=${dart_config.daily_emergency_limit}
DART_MINUTE_LIMIT=${dart_config.minute_limit}
DART_MINUTE_SAFE_LIMIT=${dart_config.minute_safe_limit}
DART_QUOTA_REQUEST_LOG_ENABLED=${dart_config.quota_request_log_enabled}
EMBEDDING_PROVIDER=${embedding_config.provider}
EMBEDDING_MODEL=${embedding_config.model}
EMBEDDING_VERSION=${embedding_config.version}
EMBEDDING_DIMENSION=${embedding_config.dimension}
OPIK_REPORT_PIPELINE_SCHEDULE=$report_schedule
OPIK_HF_CACHE_DIR=/tmp/opik-huggingface
HF_HOME=/tmp/opik-huggingface
ENV

cat >/opt/opik/airflow-admin.env <<ENV
AIRFLOW_UI_LOCAL_URL=http://127.0.0.1:8080
_AIRFLOW_WWW_USER_USERNAME=$airflow_admin_username
_AIRFLOW_WWW_USER_PASSWORD=$airflow_admin_password
ENV
chmod 600 /opt/opik/airflow.env /opt/opik/airflow-admin.env

mkdir -p /opt/opik/airflow-logs /opt/opik/airflow-config /opt/opik/airflow-plugins /opt/opik/hf-cache
chown -R 50000:0 /opt/opik/airflow-logs /opt/opik/airflow-config /opt/opik/airflow-plugins /opt/opik/hf-cache
chmod -R 775 /opt/opik/airflow-logs /opt/opik/airflow-config /opt/opik/airflow-plugins /opt/opik/hf-cache

cat >/opt/opik/airflow-compose.yml <<'YAML'
name: opik-airflow

x-airflow-common: &airflow-common
  image: opik-airflow:2.10.0
  build:
    context: /opt/opik/repo
    dockerfile: Dockerfile.airflow
  env_file:
    - /opt/opik/airflow.env
  volumes:
    - /opt/opik/repo/dags:/opt/airflow/dags
    - /opt/opik/repo/src:/opt/airflow/src
    - /opt/opik/repo/pipeline:/opt/airflow/pipeline
    - /opt/opik/repo/spark_jobs:/opt/airflow/spark_jobs
    - /opt/opik/repo/embedding:/opt/airflow/embedding
    - /opt/opik/repo/opik_config.py:/opt/airflow/opik_config.py:ro
    - /opt/opik/repo/opik_s3.py:/opt/airflow/opik_s3.py:ro
    - /opt/opik/airflow-logs:/opt/airflow/logs
    - /opt/opik/airflow-config:/opt/airflow/config
    - /opt/opik/airflow-plugins:/opt/airflow/plugins
    - /opt/opik/hf-cache:/tmp/opik-huggingface
  user: "50000:0"
  depends_on: &airflow-common-depends-on
    redis:
      condition: service_healthy

services:
  redis:
    image: redis:7-bookworm
    container_name: opik-airflow-redis
    expose:
      - "6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 20
    restart: unless-stopped

  airflow-init:
    <<: *airflow-common
    container_name: opik-airflow-init
    user: "0:0"
    entrypoint: /bin/bash
    command:
      - -c
      - |
        set -e
        airflow db migrate
        airflow users create \
          --username "$$_AIRFLOW_WWW_USER_USERNAME" \
          --firstname Airflow \
          --lastname Admin \
          --role Admin \
          --email airflow@example.com \
          --password "$$_AIRFLOW_WWW_USER_PASSWORD" \
        || airflow users reset-password \
          --username "$$_AIRFLOW_WWW_USER_USERNAME" \
          --password "$$_AIRFLOW_WWW_USER_PASSWORD"
        chown -R 50000:0 /opt/airflow/logs /opt/airflow/config /tmp/opik-huggingface
        chmod -R 775 /opt/airflow/logs /opt/airflow/config /tmp/opik-huggingface

  airflow-webserver:
    <<: *airflow-common
    container_name: opik-airflow-webserver
    command: webserver
    ports:
      # Reachable from the front proxy; access is restricted by the airflow
      # security group (front proxy SG only) and the front proxy admin allowlist.
      - "8080:8080"
    healthcheck:
      test: ["CMD", "curl", "--fail", "http://localhost:8080/health"]
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 60s
    restart: unless-stopped
    depends_on:
      <<: *airflow-common-depends-on
      airflow-init:
        condition: service_completed_successfully

  airflow-scheduler:
    <<: *airflow-common
    container_name: opik-airflow-scheduler
    command: scheduler
    healthcheck:
      test: ["CMD", "curl", "--fail", "http://localhost:8974/health"]
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 60s
    restart: unless-stopped
    depends_on:
      <<: *airflow-common-depends-on
      airflow-init:
        condition: service_completed_successfully

  airflow-worker:
    <<: *airflow-common
    container_name: opik-airflow-worker
    command: celery worker
    environment:
      DUMB_INIT_SETSID: "0"
    healthcheck:
      test:
        - CMD-SHELL
        - >-
          celery --app airflow.providers.celery.executors.celery_executor.app
          inspect ping -d "celery@$$HOSTNAME" --timeout=10
      interval: 30s
      timeout: 15s
      retries: 10
      start_period: 60s
    restart: unless-stopped
    depends_on:
      <<: *airflow-common-depends-on
      airflow-init:
        condition: service_completed_successfully

  airflow-triggerer:
    <<: *airflow-common
    container_name: opik-airflow-triggerer
    command: triggerer
    healthcheck:
      test: ["CMD-SHELL", "airflow jobs check --job-type TriggererJob --hostname \"$$HOSTNAME\""]
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 60s
    restart: unless-stopped
    depends_on:
      <<: *airflow-common-depends-on
      airflow-init:
        condition: service_completed_successfully
YAML

docker rm -f opik-airflow-redis >/dev/null 2>&1 || true

cat >/etc/systemd/system/opik-airflow.service <<'UNIT'
[Unit]
Description=OPIK Airflow Docker Compose stack
Requires=docker.service
After=docker.service network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/opik
ExecStartPre=/usr/bin/docker compose -f /opt/opik/airflow-compose.yml build
ExecStartPre=/usr/bin/docker compose -f /opt/opik/airflow-compose.yml up airflow-init
ExecStartPre=/bin/chown -R 50000:0 /opt/opik/airflow-logs /opt/opik/airflow-config /opt/opik/hf-cache
ExecStartPre=/bin/chmod -R 775 /opt/opik/airflow-logs /opt/opik/airflow-config /opt/opik/hf-cache
ExecStart=/usr/bin/docker compose -f /opt/opik/airflow-compose.yml up -d airflow-webserver airflow-scheduler airflow-worker airflow-triggerer
ExecStop=/usr/bin/docker compose -f /opt/opik/airflow-compose.yml down
TimeoutStartSec=1800

[Install]
WantedBy=multi-user.target
UNIT

systemctl daemon-reload
systemctl enable opik-airflow.service
systemctl restart opik-airflow.service

for i in $(seq 1 60); do
  if curl -fsS http://127.0.0.1:8080/health >/tmp/opik-airflow-health.json; then
    cat /tmp/opik-airflow-health.json
    break
  fi
  sleep 10
done

cat >/opt/opik/README-bootstrap.txt <<'TXT'
This instance runs OPIK Airflow through /etc/systemd/system/opik-airflow.service.
Use SSM Session Manager port forwarding for UI access; do not expose Airflow directly to the public internet.
Runtime env is generated at /opt/opik/airflow.env from Terraform non-secret values, RDS managed secrets, and optional runtime secret JSON.
Airflow UI credentials are stored root-only at /opt/opik/airflow-admin.env.
TXT
