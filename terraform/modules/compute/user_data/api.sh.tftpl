#!/bin/bash
set -euo pipefail

exec > >(tee -a /var/log/opik-api-bootstrap.log) 2>&1

dnf update -y
dnf install -y docker git awscli python3 python3-pip python3-virtualenv
systemctl enable --now docker

mkdir -p /opt/opik /data/opik /var/log/opik

cat >/opt/opik/bootstrap.env <<ENV
AWS_REGION=${aws_region}
AWS_DEFAULT_REGION=${aws_region}
S3_REGION=${aws_region}
S3_BUCKET=${data_bucket_name}
S3_BASE_PREFIX=${storage_config.s3_base_prefix}
STORAGE_BACKEND=${storage_config.storage_backend}
LOCAL_STORAGE_BASE_PATH=${storage_config.local_storage_base_path}
BRONZE_PREFIX=${storage_config.bronze_prefix}
SILVER_PREFIX=${storage_config.silver_prefix}
GOLD_PREFIX=${storage_config.gold_prefix}
EMBEDDING_PROVIDER=${embedding_config.provider}
EMBEDDING_MODEL=${embedding_config.model}
EMBEDDING_VERSION=${embedding_config.version}
EMBEDDING_DIMENSION=${embedding_config.dimension}
SERVICE_DB_ENDPOINT=${service_db_endpoint}
API_RUNTIME_SECRET_ARN=${api_secret_arn}
FAISS_INDEX_PATH=/data/opik/faiss_index.bin
FAISS_IDMAP_PATH=/data/opik/report_ids.json
CHAT_HTML_PATH=/opt/opik/repo/server/chat.html
OPIK_AGENT_ENABLED=false
ENV

%{ if repo_url != "" ~}
if [ ! -d /opt/opik/repo/.git ]; then
  rm -rf /opt/opik/repo
  git clone "${repo_url}" /opt/opik/repo
fi

python3 -m venv /opt/opik/server-venv
/opt/opik/server-venv/bin/python -m pip install --upgrade pip setuptools wheel
/opt/opik/server-venv/bin/pip install -r /opt/opik/repo/server/requirements.txt

cat >/etc/systemd/system/opik-server.service <<'UNIT'
[Unit]
Description=OPIK Server - FastAPI, FAISS, RAG
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/opik/repo/server
EnvironmentFile=/opt/opik/bootstrap.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/opik/server-venv/bin/python -m uvicorn opik_server:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
UNIT

systemctl daemon-reload
systemctl enable --now opik-server
%{ endif ~}

cat >/opt/opik/README-bootstrap.txt <<'TXT'
This instance is prepared for OPIK FastAPI, FAISS, RAG, and LangGraph agents.
The public entry point is the ALB. This instance has no public IP.
Runtime secrets must be loaded from Secrets Manager or SSM Parameter Store.
TXT
